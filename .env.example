# Replicate API
EXPO_PUBLIC_REPLICATE_API_TOKEN=your-replicate-token

# BytePlus Ark Seedream API (Direct Integration)
EXPO_PUBLIC_BYTEPLUS_ARK_API_KEY=your-byteplus-ark-api-key
# Region: 'china' (ark.cn-beijing.volces.com) or 'international' (ark.ap-southeast.bytepluses.com)
EXPO_PUBLIC_BYTEPLUS_REGION=china

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-android-key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-ios-key
EXPO_PUBLIC_REVENUECAT_WEB_KEY=your-web-key

# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://api.pics.room.ai

# Image Upload Limits
EXPO_PUBLIC_MAX_IMAGE_SIZE=10485760  # 10MB in bytes
EXPO_PUBLIC_MAX_REFERENCE_IMAGES=5
EXPO_PUBLIC_ALLOWED_IMAGE_FORMATS=image/jpeg,image/png,image/webp

# Rate Limiting (requests per minute)
EXPO_PUBLIC_GENERATION_RATE_LIMIT=5
EXPO_PUBLIC_UPLOAD_RATE_LIMIT=10
